rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - plan: string (required, enum: ['FREE', 'PRO'])
    //   - subscriptionId: string (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "bhavishyashekhawat11@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['plan', 'subscriptionId', 'updatedAt', 'analysisCount', 'lastResetDate', 'userPlan', 'role']) ||
             data.keys().hasAll(['plan']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId) || isAdmin();
      
      // Only the backend (admin) or the user themselves (with restrictions) can write
      allow create: if isOwner(userId) && (request.resource.data.plan == 'FREE' || !('plan' in request.resource.data));
      
      // Allow users to update their own usage count but not their plan
      allow update: if isAdmin() || (
        isOwner(userId) && 
        (request.resource.data.plan == resource.data.plan || !('plan' in request.resource.data)) &&
        (request.resource.data.userPlan == resource.data.userPlan || !('userPlan' in request.resource.data))
      );
    }
  }
}
