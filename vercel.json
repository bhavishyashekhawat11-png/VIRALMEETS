{
  "rewrites": [
    {
      "source": "/api/create-order",
      "destination": "/api/create-order.js"
    },
    {
      "source": "/api/webhook",
      "destination": "/api/webhook.js"
    },
    {
      "source": "/(favicon.png|preview.png|sitemap.xml|robots.txt)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
